# Example environment configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it will contain sensitive keys

# === Application Authentication ===
# Protect the API with one or more keys. Set either:
#   API_KEY=single_key        (one key)
#   API_KEYS=key1,key2,key3   (multiple keys, comma-separated)
# Leave unset to disable authentication (development only).
API_KEY=your_api_key_here

# === Pollo API Configuration ===
# Get your API key from: https://pollo.example.com/api-keys
POLLO_API_KEY=your_pollo_api_key_here

# Data directory path (where videos and metadata are stored)
POLLO_DATA_DIR=/path/to/data

# === VPN Configuration (Gluetun) ===
# VPN service provider (e.g., surfshark, nordvpn, expressvpn)
VPN_SERVICE_PROVIDER=your_vpn_provider

# VPN connection type
VPN_TYPE=wireguard

# WireGuard private key (if using WireGuard) — from your VPN provider
WIREGUARD_PRIVATE_KEY=your_wireguard_key_here

# WireGuard address assigned by your VPN provider
WIREGUARD_ADDRESSES=10.x.x.x/16

# Preferred server countries
SERVER_COUNTRIES=your_country

# Gluetun API key for authentication
GLUETUN_API_KEY=your_gluetun_api_key_here

# Gluetun control server auth — references GLUETUN_API_KEY above.
# Keep this exact format; only replace the key value.
HTTP_CONTROL_SERVER_AUTH_DEFAULT_ROLE={"auth":"apikey","apikey":"your_gluetun_api_key_here"}

# Timezone
TZ=UTC

# === For Docker Deployment ===
# Host port the app is exposed on
APP_PORT=8080

# Hostname used for HTTPS redirect (used by synology-boot.sh)
APP_HOSTNAME=your-hostname.local

# Compose stack profile: "novpn" (default) or "vpn" (route traffic through gluetun)
COMPOSE_PROFILES=novpn

# Host data directory (outside container) — absolute path on the host
POLLO_HOST_DATA_DIR=/path/to/data

# User/group the app container runs as (run `id` on the host to find your values)
PUID=1000
PGID=1000

